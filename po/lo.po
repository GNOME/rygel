#: data/rygel-preferences.ui:85
msgid "Add a directory to the list of shared directories"
msgstr "ເພີ່ມ​ໄດ​ເຣັກ​ທໍ​ຣີໃສ່​ໃນ​ລາຍ​ການ​ຂອງ​ໄດ​ເຣັກ​ທໍ​ຣີ​ທີ່​ແບ່ງ​ປັນ"

#: data/rygel-preferences.ui:86
msgid "Add shared directory"
msgstr "ເພີ່ມ​ໄດ​ເຣັກ​ທໍ​ຣີ​ທີ່​ແບ່ງ​ປັນ"

#: data/rygel-preferences.ui:92
msgid "Remove a directory from the list of shared directories"
msgstr "ລຶບ​ໄດ​ເຣັກ​ທໍ​ຣີ​ອອກ​ຈາກ​ລາຍ​ການ​ຂອງ​ໄດ​ເຣັກ​ທໍ​ຣີ​ທີ່​ແບ່ງ​ປັນ"

#: data/rygel-preferences.ui:93
msgid "Remove shared directory"
msgstr "ລຶບ​ໄດ​ເຣັກ​ທໍ​ຣີ​ທີ່​ແບ່ງ​ປັນ"

#: data/rygel-preferences.ui:121
msgid "_Share media through DLNA"
msgstr "_ແບ່ງປັນ​ມີ​ເດຍ​ຜ່ານ DLNA"

#: data/rygel-preferences.ui:195 data/rygel-preferences.ui:196
msgid "Add a network interface Rygel should serve files on"
msgstr "ເພີ່ມ​ອິນ​ເຕີ​ເຟດ​ເຄືອ​ຂ່າຍທີ່ Rygel ຄວນ​ຈະ​ໃຫ້​ບໍລິການ​ໄຟລ໌"

#: data/rygel-preferences.ui:197
msgid "Add network interface"
msgstr "ເພີ່ມ​ອິນ​ເຕີ​ເຟດ​ເຄືອ​ຂ່າຍ"

